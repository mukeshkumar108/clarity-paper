# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5435/clarity_paper

# Auth
PORT=8085
SESSION_SECRET=clarity-session-secret-change-in-production
SESSION_COOKIE_NAME=clarity.sid
SESSION_COOKIE_DOMAIN=
