# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5435/clarity_paper

# Auth
PORT=8085
SESSION_SECRET=clarity-session-secret-change-in-production
SESSION_COOKIE_NAME=clarity.sid
SESSION_COOKIE_DOMAIN=
CORS_ORIGIN=http://localhost:5175
NODE_ENV=development

# LLM (Optional)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-2.5-flash
OPENROUTER_STRUCTURED_MODEL=google/gemini-2.5-flash
OPENROUTER_EDITORIAL_MODEL=anthropic/claude-3.5-haiku
OPENROUTER_EDITORIAL_BACKUP_MODEL=google/gemini-2.5-flash
OPENROUTER_REVIEW_MODEL=
CLARITY_ENABLE_REVIEW_PASS=false

# PDF conversion (Optional — falls back to local pymupdf4llm if not set)
# USE_EXTERNAL_PDF_MD_SERVICE=true
# PDF_MD_SERVICE_URL=http://your-pdf-md-service:8010
# PDF_MD_SERVICE_TOKEN=your-bearer-token

# Frontend
VITE_API_BASE_URL=

# Search (Optional — search works without keys but rate limits apply)
# Semantic Scholar API key — free at semanticscholar.org/product/api (10 req/sec with key)
SEMANTIC_SCHOLAR_API_KEY=
# Your email — sent as polite identifier in OpenAlex API requests per their usage policy
OPENALEX_EMAIL=

# Stripe (Optional)
STRIPE_SECRET_KEY=
STRIPE_PRICE_ID=
